{
  "expo": {
    "name": "Indo Vyapar",
    "owner": "blablabla0978",
    "slug": "indo-vyapar-app",
    "scheme": "indovyapar",
    "version": "1.0.1",
    "icon": "./assets/icon.png",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ea580c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seecog.indovyapar",
      "buildNumber": "5",
      "associatedDomains": [
        "applinks:indovyapar.com",
        "applinks:www.indovyapar.com"
      ],
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSExceptionDomains": {
            "13.127.37.238": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0"
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ea580c"
      },
      "package": "com.seecog.indovyapar",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "indovyapar.com",
              "pathPrefix": "/api/auth/oauth/"
            },
            {
              "scheme": "https",
              "host": "www.indovyapar.com",
              "pathPrefix": "/api/auth/oauth/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "webUrlProd": "https://indovyapar.com",
      "webUrlDev": "http://localhost:3005",
      "eas": {
        "projectId": "83e42486-e616-4b69-adbf-cb397d36ec9e"
      }
    },
    "plugins": [
      "expo-web-browser",
      "expo-apple-authentication"
    ]
  }
}
